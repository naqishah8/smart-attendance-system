# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=change-this-password
MONGODB_URI=mongodb://admin:change-this-password@localhost:27017/attendance?authSource=admin

# PostgreSQL
PG_USER=admin
PG_PASSWORD=change-this-password

# Redis
REDIS_URI=redis://localhost:6379

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=generate-a-secure-random-string-here

# Encryption key for camera credentials (must be 32 characters)
ENCRYPT_KEY=change-this-encryption-key-32ch

# CORS
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8080

# Logging
LOG_LEVEL=info
