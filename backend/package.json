{
  "name": "cctv-attendance-backend",
  "version": "1.0.0",
  "description": "CCTV-based smart attendance system backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:stage": "jest --runInBand --forceExit --testPathPattern",
    "db:indexes": "node src/config/databaseIndexes.js",
    "migrate": "node src/migrations/migrate.js up",
    "migrate:down": "node src/migrations/migrate.js down",
    "migrate:status": "node src/migrations/migrate.js status"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.4",
    "pdfkit": "^0.14.0",
    "sharp": "^0.32.6",
    "socket.io": "^4.6.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.1",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
